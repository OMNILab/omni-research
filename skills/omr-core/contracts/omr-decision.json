{
  "skill": "omr-decision",
  "requires": [
    {
      "artifact": "evidence-map.md",
      "optional": false,
      "description": "Evidence mapping from omr-evidence"
    },
    {
      "artifact": "judgment-summary.md",
      "optional": true,
      "description": "Judgment from research planning (optional, improves decision quality)"
    }
  ],
  "produces": [
    {
      "artifact": "architecture-decision.md",
      "schema": "schemas/architecture-decision.schema.json",
      "description": "Architecture decision with alternatives, selected option, evidence refs, and risks"
    }
  ],
  "gates": [
    {
      "id": "gate_b",
      "checks": [
        "Alternatives documented",
        "Risks stated",
        "Evidence refs valid"
      ],
      "enforcement": "user-confirm",
      "description": "Verify architecture decision is sound"
    }
  ]
}